# ── Banco de dados ────────────────────────────────────────────────
POSTGRES_USER=oais
POSTGRES_PASSWORD=change-me
POSTGRES_DB=oais_araguaia
DATABASE_URL=postgresql://oais:change-me@postgres:5432/oais_araguaia?schema=public

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Portas expostas no host ───────────────────────────────────────
BACKEND_PORT=3101
FRONTEND_PORT=3100
ADMINER_PORT=8081

# ── Backend ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
JWT_SECRET=generate-a-long-random-secret
JWT_REFRESH_SECRET=generate-another-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
CORS_ORIGINS=http://localhost:3100
UPLOAD_DIR=/app/uploads

# ── Seed inicial ──────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@oaisdoaraguaia.com.br
SEED_ADMIN_PASSWORD=Admin@123

# ── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3101
