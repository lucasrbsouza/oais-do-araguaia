# Modelo do .env de PRODUÇÃO (VPS).
# Copie para `.env` no servidor e preencha os campos marcados com <...>.
# Nunca versione o .env preenchido — ele está no .gitignore.

# ── Banco de dados ────────────────────────────────────────────────
POSTGRES_USER=oais
POSTGRES_PASSWORD=<openssl rand -base64 24>
POSTGRES_DB=oais_araguaia
# A senha aqui precisa ser idêntica à de POSTGRES_PASSWORD.
# Caracteres especiais precisam de percent-encoding nesta URL.
DATABASE_URL=postgresql://oais:<mesma-senha>@postgres:5432/oais_araguaia?schema=public

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Backend ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# Mínimo de 16 caracteres — o schema Zod em src/shared/infrastructure/config/env.ts
# rejeita e o container não sobe.
JWT_SECRET=<openssl rand -base64 48>
JWT_REFRESH_SECRET=<openssl rand -base64 48, diferente do anterior>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
CORS_ORIGINS=https://oasisaraguaia.com.br
UPLOAD_DIR=/app/uploads

# ── Seed inicial (admin + 11 chalés) ──────────────────────────────
SEED_ADMIN_EMAIL=admin@oasisaraguaia.com.br
SEED_ADMIN_PASSWORD=<senha forte; trocar no primeiro login>

# ── Frontend ──────────────────────────────────────────────────────
# Vai CRAVADO na imagem no `docker compose build` (é ARG, não runtime).
# Sem porta e sem /api — o api.ts já concatena /api no caminho.
# Mudar isso depois exige rebuild do frontend.
NEXT_PUBLIC_API_URL=https://oasisaraguaia.com.br

# ── Traefik / Let's Encrypt ───────────────────────────────────────
# Recebe os avisos de expiração do certificado. Use um e-mail que você lê.
ACME_EMAIL=<seu@email.com>

# ── Cloudflare ────────────────────────────────────────────────────
# Token de API com permissão Zone:DNS:Edit na zona oasisaraguaia.com.br.
# Usado só pelo desafio DNS-01 do Let's Encrypt. NÃO use a Global API Key:
# ela dá acesso total à conta e não pode ser limitada por escopo.
CF_DNS_API_TOKEN=<token da Cloudflare>

# Faixas de IP da Cloudflare, separadas por vírgula. NÃO preencha na mão —
# `sudo ./scripts/cloudflare-ips.sh` escreve esta linha e sincroniza o ufw.
CLOUDFLARE_IPS=
